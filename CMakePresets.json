{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
		    "toolchainFile": "${sourceDir}/cmake/gcc-arm-none-eabi.cmake",
            "cacheVariables": {
            }
        },
        {
            "name": "Debug",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "DebugBL",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "FLASH_LINKER_SCRIPT": "${sourceDir}/STM32F072XX_FLASH_BL.ld"
            }
        },
        {
            "name": "Release",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "ReleaseBL",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "FLASH_LINKER_SCRIPT": "${sourceDir}/STM32F072XX_FLASH_BL.ld"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Debug",
            "configurePreset": "Debug"
        },
        {
            "name": "DebugBL",
            "configurePreset": "DebugBL"
        },
        {
            "name": "Release",
            "configurePreset": "Release"
        },
        {
            "name": "ReleaseBL",
            "configurePreset": "ReleaseBL"
        }
    ]
}